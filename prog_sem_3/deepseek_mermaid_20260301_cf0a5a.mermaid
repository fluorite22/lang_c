graph TD
    A[Начало] --> B[Инициализация: 
        - Запрос имени игрока
        - Установка начальных параметров]
    B --> C[Основной игровой цикл]
    
    C --> D{Хочет ли игрок 
        играть?}
    D -->|Нет| E[Конец]
    D -->|Да| F[initialize_game]
    
    F --> F1[create_deck - создание колоды]
    F1 --> F2[shuffle_deck - перемешивание]
    F2 --> F3[determine_trump - определение козыря]
    F3 --> F4[deal_cards - раздача карт]
    F4 --> F5[Определение первого атакующего]
    F5 --> G[Игровой раунд]
    
    G --> H{game_over? 
        (проверка окончания)}
    H -->|Да| I[Определение победителя]
    I --> D
    
    H -->|Нет| J[Очистка экрана и 
        отображение информации]
    J --> K{current_player?}
    
    K -->|0 игрок| L[player_turn]
    K -->|1 компьютер| M[computer_turn]
    
    L --> L1{Атакует или 
        защищается?}
    L1 -->|Атака| L2[Выбор карты для атаки]
    L2 --> L3{Выбор валидный?}
    L3 -->|Нет| L2
    L3 -->|Да| L4[Добавить карту на стол]
    L4 --> L5[current_player = 
        1 - current_player]
    L5 --> G
    
    L1 -->|Защита| L6[Выбор карты для защиты]
    L6 --> L7{Взять карты 
        или защищаться?}
    L7 -->|Взять| L8[Игрок берёт все карты]
    L8 --> L9[attacker = 1 - attacker]
    L9 --> L10[current_player = attacker]
    L10 --> G
    
    L7 -->|Защита| L11{Защита валидная?}
    L11 -->|Нет| L6
    L11 -->|Да| L12[Добавить защиту на стол]
    L12 --> L13{Все карты 
        отбиты?}
    L13 -->|Да| L14[Очистить стол]
    L14 --> L15[attacker = 1 - attacker]
    L15 --> L16[current_player = attacker]
    L16 --> L17[draw_cards - добор]
    L17 --> G
    
    L13 -->|Нет| L18[current_player = attacker]
    L18 --> G
    
    M --> M1{Атакует или 
        защищается?}
    M1 -->|Атака| M2[Выбор младшей карты]
    M2 --> M3[Добавить карту на стол]
    M3 --> M4[current_player = 
        1 - current_player]
    M4 --> G
    
    M1 -->|Защита| M5{Есть чем 
        защищаться?}
    M5 -->|Да| M6[Защититься первой 
        подходящей картой]
    M6 --> M7{Все карты 
        отбиты?}
    M7 -->|Да| M8[Очистить стол]
    M8 --> M9[attacker = 1 - attacker]
    M9 --> M10[current_player = attacker]
    M10 --> M11[draw_cards - добор]
    M11 --> G
    
    M7 -->|Нет| M12[current_player = attacker]
    M12 --> G
    
    M5 -->|Нет| M13[Компьютер берёт карты]
    M13 --> M14[attacker = 1 - attacker]
    M14 --> M15[current_player = attacker]
    M15 --> G